# MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/jobglobe?retryWrites=true&w=majority

# RapidAPI - JSearch (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=jsearch.p.rapidapi.com

# AWS SES - Email verification (optional for local development)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_SES_FROM_EMAIL=no-reply@yourdomain.com

# Google Analytics
NEXT_PUBLIC_GA_ID=your_ga_measurement_id
